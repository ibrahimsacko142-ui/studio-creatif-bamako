# Variables d'environnement pour Studio Créatif Bamako
# Copiez ce fichier en .env et remplissez les valeurs

# === BASE DE DONNÉES ===
# Pour développement local (SQLite) :
DATABASE_URL="file:./dev.db"

# Pour production (PostgreSQL — Vercel Postgres, Supabase, Neon, Railway) :
# DATABASE_URL="postgresql://user:password@host:5432/studio_creatif?schema=public"

# === CLÉS API IA ===
# IMPORTANT : Ne JAMAIS committer ces clés dans Git
# Ne JAMAIS les exposer côté client (toujours via routes API Next.js)

# Z.AI SDK — passerelle unifiée GPT-5 + Grok + Kimi + Gemini
# Crée un fichier .z-ai-config à la racine avec :
# {
#   "baseUrl": "https://api.z.ai/api/v1",
#   "apiKey": "sk-ai-v1-...",
#   "chatId": "studio-creatif-bamako",
#   "userId": "ibrahim-sacko"
# }

# Ou via variables d'environnement :
# ZAI_API_KEY="sk-ai-v1-votre-cle-ici"
# ZAI_BASE_URL="https://api.z.ai/api/v1"

# === NEXTAUTH (pour la Phase 5 — authentification) ===
# NEXTAUTH_SECRET="generer-avec-openssl-rand-base64-32"
# NEXTAUTH_URL="https://votre-domaine.com"

# === TALIOPAY (pour la Phase 4 — paiement) ===
# TALIOPAY_API_KEY="votre-cle-taliopay"
# TALIOPAY_SECRET="votre-secret-taliopay"
# TALIOPAY_WEBHOOK_SECRET="votre-webhook-secret"

# === APP ===
NEXT_PUBLIC_APP_NAME="Studio Créatif Bamako"
NEXT_PUBLIC_APP_URL="https://votre-domaine.com"
NEXT_PUBLIC_WHATSAPP_CONTACT="+223 7X XX XX XX"
